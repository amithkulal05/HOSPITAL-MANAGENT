<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Hospital Management</display-name>

    <!-- Welcome File -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Add Patient -->
    <servlet>
        <servlet-name>Add</servlet-name>
        <servlet-class>com.servlet.AddPatientServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Add</servlet-name>
        <url-pattern>/addPatient</url-pattern>
    </servlet-mapping>

    <!-- Update Patient -->
    <servlet>
        <servlet-name>Update</servlet-name>
        <servlet-class>com.servlet.UpdatePatientServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Update</servlet-name>
        <url-pattern>/updatePatient</url-pattern>
    </servlet-mapping>

    <!-- Delete Patient -->
    <servlet>
        <servlet-name>Delete</servlet-name>
        <servlet-class>com.servlet.DeletePatientServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Delete</servlet-name>
        <url-pattern>/deletePatient</url-pattern>
    </servlet-mapping>

    <!-- Display Patients -->
    <servlet>
        <servlet-name>Display</servlet-name>
        <servlet-class>com.servlet.DisplayPatientsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Display</servlet-name>
        <url-pattern>/displayPatients</url-pattern>
    </servlet-mapping>

    <!-- Report -->
    <servlet>
        <servlet-name>Report</servlet-name>
        <servlet-class>com.servlet.ReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Report</servlet-name>
        <url-pattern>/report</url-pattern>
    </servlet-mapping>

</web-app>